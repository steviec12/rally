generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth tables ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Rally domain models ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?   // NextAuth field name; PRD calls it "avatar"
  bio           String?
  interests     String[]
  location      String?
  locationLat   Float?    // nullable until user sets location
  locationLng   Float?
  rating        Float?    // null = new user; matches ScoringUser.rating: number | null
  activityCount Int       @default(0)
  createdAt     DateTime  @default(now())

  accounts         Account[]
  sessions         Session[]
  hostedActivities Activity[]    @relation("HostedActivities")
  joinRequests     JoinRequest[] @relation("RequesterJoinRequests")
  ratingsGiven     Rating[]      @relation("RatingsGiven")
  ratingsReceived  Rating[]      @relation("RatingsReceived")
}

model Activity {
  id          String         @id @default(cuid())
  hostId      String
  title       String
  description String?
  tags        String[]
  dateTime    DateTime
  location    String
  locationLat Float
  locationLng Float
  maxSpots    Int
  status      ActivityStatus @default(open)
  createdAt   DateTime       @default(now())

  host         User          @relation("HostedActivities", fields: [hostId], references: [id])
  joinRequests JoinRequest[]
  ratings      Rating[]
}

enum ActivityStatus {
  open
  full
  completed
  cancelled
}

model JoinRequest {
  id                 String            @id @default(cuid())
  activityId         String
  userId             String
  status             JoinRequestStatus @default(pending)
  compatibilityScore Float?
  createdAt          DateTime          @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation("RequesterJoinRequests", fields: [userId], references: [id])

  @@unique([activityId, userId])
}

enum JoinRequestStatus {
  pending
  approved
  declined
}

model Rating {
  id         String   @id @default(cuid())
  raterId    String
  rateeId    String
  activityId String
  score      Int      // 1–5, enforced at application layer
  createdAt  DateTime @default(now())

  rater    User     @relation("RatingsGiven", fields: [raterId], references: [id])
  ratee    User     @relation("RatingsReceived", fields: [rateeId], references: [id])
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([raterId, rateeId, activityId])
}
